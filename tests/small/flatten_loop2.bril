# ARGS: 3
@main(x: int) {
  i: int = const 0;
.outer:
  maxi: int = const 10;
  notdone: bool = lt i maxi;
  one: int = const 1;
  i: int = add i one;
  j: int = const 0;
  br notdone .inner .end;
.inner:
  maxj: int = const 5;
  notdone: bool = lt j maxj;
  br notdone .body .outer;
.body:
  res: int = mul i maxi;
  res: int = add res j;
  print res;
  print x;
  one: int = const 1;
  j: int = add j one;
  jmp .inner;
.end:
  ret;
}